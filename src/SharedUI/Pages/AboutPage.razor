@page "/About"

<div class="Stage">
    <MarketingHero Title="Built for owner-operators and"
                   Highlight="brokers"
                   Subtitle="Wolfs Trucking Co. ships freight, hires drivers, and runs dispatch — all on one platform with a marketplace, real-time tracking, voice navigation, and a dispatcher you can call."
                   CtaHref="Marketplace"
                   CtaLabel="Browse the marketplace" />

    <div class="Grid">
        <div class="Card">
            <div class="ServiceIcon">📦</div>
            <h2>Freight marketplace</h2>
            <p>Customers post jobs and pay by card or cash on delivery. Drivers accept directly from the dashboard.</p>
        </div>
        <div class="Card">
            <div class="ServiceIcon">📍</div>
            <h2>Real-time tracking</h2>
            <p>Customers watch shipments live with the same precision as a rideshare app.</p>
        </div>
        <div class="Card">
            <div class="ServiceIcon">🧭</div>
            <h2>Voice navigation</h2>
            <p>Turn-by-turn voice for drivers with a progress banner above the map and off-route detection.</p>
        </div>
        <div class="Card">
            <div class="ServiceIcon">📞</div>
            <h2>Dispatcher you can call</h2>
            <p>Hold the call button and ask anything. Drivers see their pay, customers see their jobs, admins see the whole platform.</p>
        </div>
    </div>
</div>
