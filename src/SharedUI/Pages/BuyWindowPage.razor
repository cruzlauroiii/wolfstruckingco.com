@page "/Buy/Window"

<div class="Stage PageStage">
    <h1>Delivery window</h1>
    <p>Step 3 of 5 — when can the driver come?</p>
    <div class="Step5"><div class="Bar D"></div><div class="Bar D"></div><div class="Bar D"></div><div class="Bar T"></div><div class="Bar T"></div></div>

    <div class="Card CardForm">
        <div class="Row"><div class="Field"><label>Earliest day</label><input type="text" value="June 15" /></div><div class="Field"><label>Latest day</label><input type="text" value="June 17" /></div></div>
