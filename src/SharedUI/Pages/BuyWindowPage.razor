@page "/Buy/Window"

<div class="Stage" style="padding:14px">
    <h1 style="font-size:1.4rem;margin-bottom:6px">Delivery window</h1>
    <p style="color:var(--text-muted);font-size:.9rem;margin-bottom:14px">Step 3 of 5 — when can the driver come?</p>
    <div style="display:flex;gap:4px;margin-bottom:14px"><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--border)"></div><div style="flex:1;height:4px;background:var(--border)"></div></div>

    <div class="Card" style="padding:14px">
        <div class="Row"><div class="Field"><label>Earliest day</label><input type="text" value="June 15" /></div><div class="Field"><label>Latest day</label><input type="text" value="June 17" /></div></div>
        <div class="Field"><label>Preferred time</label><select><option>Anytime 09:00 — 22:00</option><option>Morning 09:00 — 12:00</option><option>Afternoon 12:00 — 18:00</option><option>Evening 18:00 — 22:00</option></select></div>
        <button class="Btn Block">Next · payment</button>
    </div>
</div>
