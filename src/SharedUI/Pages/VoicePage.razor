@page "/Voice"

<div class="Stage VoiceStage">
    <h1>📞 Voice agent</h1>
    <p class="Sub">Press and hold the button below to speak. The agent listens, then replies in voice.</p>

    <div class="Card VoiceCard">
        <div class="VoicePulse" aria-hidden="true">🎙️</div>
        <form action="/wolfstruckingco.com/Chat/" method="get" class="VoiceForm">
            <label for="VoiceInput" class="VoiceLabel">What do you need to ship?</label>
            <input id="VoiceInput" name="msg" type="text" placeholder="Tell the agent — text or paste your transcribed voice" autofocus required />
            <button type="submit" class="Btn VoiceSubmit">Send to agent ➤</button>
        </form>
        <p class="VoiceHint">Tip: tap the mic icon on your keyboard to dictate. The agent treats text and dictated voice the same.</p>
    </div>

    <div class="Card VoiceCallout">
        <h2>How voice works here</h2>
        <ul>
            <li>📨 Your message goes to the dispatcher chat — same thread as text.</li>
            <li>🚛 The dispatcher composes drivers, legs, customs, and badges from what you say.</li>
            <li>📍 Track the resulting job from the marketplace or driver dashboard.</li>
        </ul>
    </div>
</div>
