@page "/Sell/Pay"

<div class="Stage" style="padding:14px">
    <h1 style="font-size:1.4rem;margin-bottom:6px">Pay & badges</h1>
    <p style="color:var(--text-muted);font-size:.9rem;margin-bottom:14px">Step 5 of 5 — set the pay and badges drivers need.</p>
    <div style="display:flex;gap:4px;margin-bottom:14px"><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div></div>

    <div class="Card" style="padding:14px">
        <div class="Row"><div class="Field"><label>Total pay</label><input type="text" value="$2,520" /></div><div class="Field"><label>Legs</label><input type="text" value="4" /></div></div>
        <div class="Field"><label>Required badges</label>
            <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:6px">
                <span style="background:#eef2ff;color:#1e40af;padding:6px 10px;border-radius:14px;font-size:.78rem;font-weight:700">CDL</span>
                <span style="background:#fef3c7;color:#92400e;padding:6px 10px;border-radius:14px;font-size:.78rem;font-weight:700">Port pass</span>
                <span style="background:#ecfccb;color:#3f6212;padding:6px 10px;border-radius:14px;font-size:.78rem;font-weight:700">Interstate</span>
                <span style="background:#fce7f3;color:#9d174d;padding:6px 10px;border-radius:14px;font-size:.78rem;font-weight:700">Team driver</span>
                <span style="background:#dbeafe;color:#1e3a8a;padding:6px 10px;border-radius:14px;font-size:.78rem;font-weight:700">Auto-handling</span>
                <span style="background:#fee2e2;color:#7f1d1d;padding:6px 10px;border-radius:14px;font-size:.78rem;font-weight:700">China export</span>
            </div>
        </div>
        <button class="Btn Block">Publish job</button>
    </div>
</div>
