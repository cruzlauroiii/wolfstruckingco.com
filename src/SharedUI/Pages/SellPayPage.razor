@page "/Sell/Pay"

<div class="Stage PageStage">
    <h1>Pay & badges</h1>
    <p>Step 5 of 5 — set the pay and badges drivers need.</p>
    <div class="Step5"><div class="Bar D"></div><div class="Bar D"></div><div class="Bar D"></div><div class="Bar D"></div><div class="Bar D"></div></div>

    <div class="Card CardForm">
        <div class="Row"><div class="Field"><label>Total pay</label><input type="text" value="$2,520" /></div><div class="Field"><label>Legs</label><input type="text" value="4" /></div></div>
        <div class="Field"><label>Required badges</label>
            <div class="BadgeChips">
                <span class="BadgeChip Cdl">CDL</span>
                <span class="BadgeChip PortPass">Port pass</span>
                <span class="BadgeChip Interstate">Interstate</span>
                <span class="BadgeChip Team">Team driver</span>
                <span class="BadgeChip Auto">Auto-handling</span>
                <span class="BadgeChip China">China export</span>
            </div>
        </div>
        <button class="Btn Block">Publish job</button>
    </div>
</div>
