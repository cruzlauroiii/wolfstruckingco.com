@page "/CareerAgent"

<MarketingHero Title="Wolfs"
               Highlight="Career Agent"
               Subtitle="AI-driven role placement and interview prep for trucking professionals."
               CtaHref="/Chat"
               CtaLabel="Start application →" />

<div class="Grid">
    <div class="Card">
        <div class="ServiceIcon">🎯</div>
        <h3>Role matching</h3>
        <p>Tell the agent your CDL class, endorsements, location, and pay expectation. It returns the open roles you qualify for.</p>
    </div>
    <div class="Card">
        <div class="ServiceIcon">🎤</div>
        <h3>Interview prep</h3>
        <p>Practice DOT compliance questions, log book scenarios, and pre-trip inspection drills via voice.</p>
    </div>
    <div class="Card">
        <div class="ServiceIcon">📋</div>
        <h3>Document review</h3>
        <p>Upload your CDL, TWIC, medical, and hazmat. The agent flags expirations and missing items before you apply.</p>
    </div>
</div>
