@page "/Track"

<div class="Stage" style="padding:14px">
    <h1 style="font-size:1.4rem;margin-bottom:6px">Track your delivery</h1>
    <p style="color:var(--text-muted);font-size:.9rem;margin-bottom:14px">@(Latest?["subject"]?.ToString() ?? "Live shipment status")</p>

    <div class="Card" style="padding:0;margin-bottom:14px;overflow:hidden">
        <svg viewBox="0 0 414 220" width="100%" height="220" preserveAspectRatio="xMidYMid slice" style="display:block;background:linear-gradient(180deg,#cfe2f3 0%,#7eb8d4 100%)">
            <path d="M 0 200 Q 100 195 200 198 Q 300 202 414 200 L 414 220 L 0 220 Z" fill="#2563eb" opacity=".22"/>
            <text x="40" y="40" font-size="11" fill="#1e3a8a" font-weight="700">Shanghai</text>
            <circle cx="40" cy="50" r="6" fill="#22c55e" stroke="#fff" stroke-width="2"/>
            <text x="350" y="40" font-size="11" fill="#1e3a8a" font-weight="700" text-anchor="end">Port of LA</text>
            <circle cx="380" cy="50" r="6" fill="#ff6b35" stroke="#fff" stroke-width="2"/>
            <path d="M 40 50 Q 200 80 380 50" fill="none" stroke="#22c55e" stroke-width="3" stroke-dasharray="@($"{ShipProgress},100")" pathLength="100"/>
            <path d="M 40 50 Q 200 80 380 50" fill="none" stroke="#94a3b8" stroke-width="2" stroke-dasharray="3 4"/>
            <g transform="translate(@(ShipX),@(ShipY))">
                <circle cx="0" cy="0" r="14" fill="#0ea5e9" opacity=".22"/>
                <text x="0" y="6" text-anchor="middle" font-size="20">🚢</text>
            </g>
            <text x="207" y="200" text-anchor="middle" font-size="9" fill="#1e3a8a" font-weight="700">Pacific Ocean · GPS in car</text>
        </svg>
    </div>

    <div class="Card" style="padding:16px;margin-bottom:14px">
        <div style="font-size:.78rem;text-transform:uppercase;letter-spacing:1px;color:var(--accent);font-weight:800;margin-bottom:6px">Current location</div>
        <div style="font-weight:700;font-size:1.1rem;margin-bottom:10px">@(Latest?["note"]?.ToString() ?? "Awaiting first update")</div>
        <div style="display:flex;gap:14px;align-items:center">
            <div style="font-size:1.6rem">🚚</div>
            <div style="flex:1;min-width:0">
                <div style="font-size:.82rem;color:var(--text-muted)">Last update</div>
                <div style="font-weight:700;font-size:.92rem">@(Latest?["at"]?.ToString() ?? "—")</div>
            </div>
        </div>
    </div>

    <div style="position:relative;padding-left:14px">
        @for (int I = 0; I < Steps.Count; I++)
        {
            var S = Steps[I];
            var IsCurrent = I == 0;
            var IsDone = !IsCurrent;
            <div style="display:flex;gap:14px;align-items:flex-start;margin-bottom:14px">
                <div style="width:14px;height:14px;border-radius:50%;flex:none;margin-top:4px;@(IsCurrent ? "background:var(--accent);box-shadow:0 0 0 4px rgba(255,107,53,.18)" : "background:#22c55e")"></div>
                <div style="flex:1;min-width:0">
                    <div style="font-weight:700;font-size:.92rem">@(S["subject"]?.ToString())</div>
                    <div style="color:var(--text-muted);font-size:.8rem;margin-top:2px">@(S["at"]?.ToString())</div>
                </div>
                @if (IsDone)
                {
                    <span style="font-size:.74rem;font-weight:700;color:#14532d;background:rgba(34,197,94,.12);padding:3px 8px;border-radius:10px">Done</span>
                }
            </div>
        }
    </div>

    <div class="Card" style="margin-top:14px;background:#eef2ff;border-color:#1e40af;padding:12px 14px">
        <div style="font-size:.78rem;text-transform:uppercase;letter-spacing:1px;color:#1e40af;font-weight:800;margin-bottom:2px">Estimated arrival</div>
        <div style="font-weight:700;font-size:1rem">June 15 · 10:00 PM Wilmington time</div>
    </div>
</div>

