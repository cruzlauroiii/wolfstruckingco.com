@page "/Interview"

<div class="Stage" style="padding:14px">
    <h1 style="font-size:1.4rem;margin-bottom:6px">Chat with Agent</h1>
    <p style="color:var(--text-muted);font-size:.9rem;margin-bottom:14px">Quick safety questions. Speak or type your answer.</p>

    <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:14px">
        <div style="align-self:flex-start;max-width:80%;background:#f3f6fa;border:1px solid var(--border);border-radius:14px 14px 14px 4px;padding:10px 14px;font-size:.95rem">
            <strong style="color:var(--accent);font-size:.78rem;display:block;margin-bottom:2px">Agent</strong>
            @(Latest?["subject"]?.ToString() ?? "Tell me about your driving experience.")
        </div>
        <div style="align-self:flex-end;max-width:80%;background:var(--accent);color:#fff;border-radius:14px 14px 4px 14px;padding:10px 14px;font-size:.95rem">
            <strong style="font-size:.78rem;display:block;margin-bottom:2px;opacity:.9">You</strong>
            @(Latest?["note"]?.ToString() ?? "")
        </div>
    </div>

    <div style="display:flex;gap:8px;align-items:center;background:#fff;border:1px solid var(--border);border-radius:24px;padding:6px 10px">
        <input type="text" style="flex:1;border:none;outline:none;padding:10px;font-size:.95rem" placeholder="Type your answer…" />
        <button class="Btn" style="border-radius:50%;width:44px;height:44px;padding:0;font-size:1rem">🎙️</button>
    </div>
</div>

