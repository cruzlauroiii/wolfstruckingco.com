@page "/Job/Offer"

<div class="Stage" style="padding:14px">
    <div style="font-size:.78rem;text-transform:uppercase;letter-spacing:1px;color:var(--accent);font-weight:800;margin-bottom:4px">New job offer</div>
    <h1 style="font-size:1.4rem;margin-bottom:6px">@Title</h1>
    <p style="color:var(--text-muted);font-size:.9rem;margin-bottom:14px">@Subtitle</p>

    <div class="Card" style="padding:16px;margin-bottom:14px">
        <div style="display:flex;justify-content:space-between;gap:12px;margin-bottom:12px">
            <div>
                <div style="font-size:.74rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.7px;font-weight:700">Pay</div>
                <div style="font-weight:800;font-size:1.4rem;color:var(--accent)">$@Pay</div>
            </div>
            <div>
                <div style="font-size:.74rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.7px;font-weight:700">Distance</div>
                <div style="font-weight:800;font-size:1.4rem">@Distance</div>
            </div>
            <div>
                <div style="font-size:.74rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.7px;font-weight:700">Hours</div>
                <div style="font-weight:800;font-size:1.4rem">@Hours</div>
            </div>
        </div>
        <div style="font-size:.9rem;line-height:1.45">
            <div style="margin-bottom:4px"><strong>From:</strong> @From</div>
            <div style="margin-bottom:4px"><strong>To:</strong> @To</div>
            <div style="color:var(--text-muted);font-size:.82rem;margin-top:6px">Starts @Starts · grace @Grace min</div>
        </div>
    </div>

    <div class="Card" style="padding:14px;margin-bottom:14px">
        <h2 style="font-size:1rem;margin-bottom:8px">What you do</h2>
        <ol style="padding-left:20px;color:var(--text-muted);font-size:.86rem;line-height:1.6;margin:0">
            <li>Show your badges at pickup.</li>
            <li>Inspect the car and seal numbers.</li>
            <li>Follow the turn-by-turn map.</li>
            <li>Hand off to the next driver or buyer.</li>
        </ol>
    </div>

    <div style="display:flex;gap:8px">
        <button class="Btn" style="flex:1">Accept job</button>
        <button class="Btn Ghost" style="flex:1">Decline</button>
    </div>
</div>

