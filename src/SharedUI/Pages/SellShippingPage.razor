@page "/Sell/Shipping"

<div class="Stage" style="padding:14px">
    <h1 style="font-size:1.4rem;margin-bottom:6px">Shipping</h1>
    <p style="color:var(--text-muted);font-size:.9rem;margin-bottom:14px">Step 3 of 5 — container, broker, and customs value.</p>
    <div style="display:flex;gap:4px;margin-bottom:14px"><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--border)"></div><div style="flex:1;height:4px;background:var(--border)"></div></div>

    <div class="Card" style="padding:14px">
        <div class="Row"><div class="Field"><label>Container size</label><select><option>40-ft high-cube</option><option>40-ft standard</option><option>20-ft</option></select></div><div class="Field"><label>Quantity</label><input type="text" value="1" /></div></div>
        <div class="Field"><label>Customs broker</label><input type="text" value="Sinotrans International" /></div>
        <div class="Field"><label>Declared value</label><input type="text" value="$48,500 USD" /></div>
        <button class="Btn Block">Next · drop-off</button>
    </div>
</div>
