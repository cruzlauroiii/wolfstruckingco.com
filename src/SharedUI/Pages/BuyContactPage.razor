@page "/Buy/Contact"

<div class="Stage" style="padding:14px">
    <h1 style="font-size:1.4rem;margin-bottom:6px">Contact at delivery</h1>
    <p style="color:var(--text-muted);font-size:.9rem;margin-bottom:14px">Step 2 of 5 — how the driver reaches you at the door.</p>
    <div style="display:flex;gap:4px;margin-bottom:14px"><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--border)"></div><div style="flex:1;height:4px;background:var(--border)"></div><div style="flex:1;height:4px;background:var(--border)"></div></div>

    <div class="Card" style="padding:14px">
        <div class="Row"><div class="Field"><label>Phone</label><input type="text" value="+1 910 555 0148" /></div><div class="Field"><label>Reach until</label><input type="text" value="22:00 local" /></div></div>
        <div class="Field"><label>Backup contact</label><input type="text" value="Jordan · neighbour at 1416 Oak St" /></div>
        <button class="Btn Block">Next · delivery window</button>
    </div>
</div>
