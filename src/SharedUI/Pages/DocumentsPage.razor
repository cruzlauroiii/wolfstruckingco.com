@page "/Documents"

<div class="Stage" style="padding:14px">
    <h1 style="font-size:1.4rem;margin-bottom:6px">My Documents</h1>
    <p style="color:var(--text-muted);font-size:.9rem;margin-bottom:14px">Upload every certificate that matches a badge. Tap a card to add or replace.</p>

    @foreach (var Cert in Certs)
    {
        var Uploaded = UploadedSubjects.Any(S => S.Contains(Cert.Match, System.StringComparison.OrdinalIgnoreCase));
        <div class="Card Compact" style="display:flex;gap:10px;align-items:center;padding:10px 12px;margin-bottom:6px">
            <div style="width:36px;height:36px;border-radius:8px;background:@(Uploaded ? "rgba(34,197,94,.14)" : "rgba(148,163,184,.18)");color:@(Uploaded ? "#14532d" : "#475569");display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:800;flex:none">@(Uploaded ? "✓" : "+")</div>
            <div style="flex:1;min-width:0">
                <div style="font-weight:700;font-size:.92rem">@Cert.Name</div>
                <div style="color:var(--text-muted);font-size:.78rem">@Cert.Detail</div>
            </div>
            <button class="Btn Ghost" style="font-size:.8rem;padding:6px 10px;min-height:32px">@(Uploaded ? "Replace" : "Upload")</button>
        </div>
    }

    <div style="margin-top:14px;border:2px dashed var(--border);border-radius:12px;padding:18px;text-align:center;background:#f9fafb">
        <div style="font-size:1.6rem;margin-bottom:4px">📎</div>
        <div style="font-weight:700;margin-bottom:2px">Upload more</div>
        <div style="color:var(--text-muted);font-size:.82rem">JPG, PNG, or PDF up to 10 MB.</div>
        <button class="Btn" style="margin-top:10px">Choose file</button>
    </div>
</div>

