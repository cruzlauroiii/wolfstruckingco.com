@page "/"

<div class="Stage">
    <MarketingHero Title="Move anything, "
                   Highlight="anywhere — on demand"
                   Subtitle="Wolfs Trucking Co. is a logistics platform. Tell our agent what you need shipped — a car, a pallet, a container, a single crate — and the agent dynamically composes the legs, drivers, and credentials needed to deliver it. Whoever you are, whatever the cargo, the network adapts."
                   CtaHref="Sell/Chat"
                   CtaLabel="Tell the agent what to ship" />

    <div class="Card" style="display:flex;gap:14px;align-items:center;padding:16px;margin-top:14px;background:linear-gradient(135deg,#fff5e6 0%,rgba(255,107,53,.06) 100%);border:2px solid var(--accent)">
        <div style="font-size:2rem;flex:none">📦</div>
        <div style="flex:1;min-width:0">
            <div style="font-weight:800;font-size:1rem;margin-bottom:2px">Have something to ship?</div>
            <div style="color:var(--text-muted);font-size:.86rem">Chat with the agent. The platform composes pickup, legs, customs, and final delivery on the fly.</div>
        </div>
        <a href="Sell/Chat" class="Btn" style="flex:none">Start a shipment</a>
    </div>

    <div class="Card" style="display:flex;gap:14px;align-items:center;padding:16px;margin-top:10px;background:#f3f6fa">
        <div style="font-size:2rem;flex:none">🚛</div>
        <div style="flex:1;min-width:0">
            <div style="font-weight:800;font-size:1rem;margin-bottom:2px">Want to drive for Wolfs?</div>
            <div style="color:var(--text-muted);font-size:.86rem">Sign in, then chat with the agent — get matched to the legs that fit your badges.</div>
        </div>
        <a href="Apply" class="Btn Ghost" style="flex:none">Apply to drive</a>
    </div>

    <div class="Card" style="display:flex;gap:14px;align-items:center;padding:16px;margin-top:10px;background:#eef2ff;border:1px solid #1e40af">
        <div style="font-size:2rem;flex:none">📍</div>
        <div style="flex:1;min-width:0">
            <div style="font-weight:800;font-size:1rem;margin-bottom:2px">Need to track a shipment?</div>
            <div style="color:var(--text-muted);font-size:.86rem">Live GPS, ocean tracking, customs status, and door delivery — all in one feed.</div>
        </div>
        <a href="Track" class="Btn Ghost" style="flex:none">Track</a>
    </div>

    <div class="Grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr))">
        <div class="Card">
            <div style="font-size:2rem">🤖</div>
            <h2>Agent-composed jobs</h2>
            <p style="color:var(--text-muted);font-size:.88rem;line-height:1.6">No fixed job templates. Tell the agent what to move; it picks origin, legs, customs, badges, and drivers on the fly.</p>
        </div>
        <div class="Card">
            <div style="font-size:2rem">🧭</div>
            <h2>Voice navigation</h2>
            <p style="color:var(--text-muted);font-size:.88rem;line-height:1.6">Turn-by-turn voice for drivers with live GPS, traffic-aware ETA, and auto-rerouting on congestion.</p>
        </div>
        <div class="Card">
            <div style="font-size:2rem">📍</div>
            <h2>Real-time tracking</h2>
            <p style="color:var(--text-muted);font-size:.88rem;line-height:1.6">Land, ocean, customs, and door — every leg streams live to whoever is watching.</p>
        </div>
        <div class="Card">
            <div style="font-size:2rem">📞</div>
            <h2>Dispatcher you can call</h2>
            <p style="color:var(--text-muted);font-size:.88rem;line-height:1.6">Hold the call button and ask anything. Send photos, receipts, or voice — the agent acts on behalf of any driver, customer, or admin.</p>
        </div>
        <div class="Card">
            <div style="font-size:2rem">📎</div>
            <h2>Inline credential intake</h2>
            <p style="color:var(--text-muted);font-size:.88rem;line-height:1.6">License, port pass, customs broker letter, team-driver papers — attach as chat bubbles with thumbnails. The agent assigns the right badge to the right leg.</p>
        </div>
        <div class="Card">
            <div style="font-size:2rem">📊</div>
            <h2>Live numbers</h2>
            <p style="color:var(--text-muted);font-size:.88rem;line-height:1.6">Revenue, payouts, customs duties, on-time rate, active jobs — all computed from real CRUD events, never seeded.</p>
        </div>
    </div>

    <div class="Card" style="text-align:center;margin-top:32px">
        <h2>Get started</h2>
        <p style="color:var(--text-muted);font-size:.86rem;margin-bottom:14px">Sign in to start a shipment, drive a leg, or oversee operations.</p>
        <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:center">
            <a class="Btn" href="Login">Sign in</a>
            <a class="Btn Ghost" href="SignUp">Create account</a>
        </div>
    </div>
</div>
