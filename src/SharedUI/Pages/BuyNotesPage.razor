@page "/Buy/Notes"

<div class="Stage PageStage">
    <h1>Special instructions</h1>
    <p>Step 5 of 5 — any extra requests for the driver.</p>
    <div class="Step5"><div class="Bar D"></div><div class="Bar D"></div><div class="Bar D"></div><div class="Bar D"></div><div class="Bar D"></div></div>

    <div class="Card CardForm">
        <div class="CheckList">
            <label><input type="checkbox" checked /> Photo proof of delivery required</label>
            <label><input type="checkbox" checked /> Photo ID check at door</label>
            <label><input type="checkbox" /> Park in driveway, do not block street</label>
            <label><input type="checkbox" /> Call 15 minutes before arrival</label>
            <label><input type="checkbox" checked /> Add cargo insurance ($150)</label>
        </div>
        <div class="Field FieldGap"><label>Note for the driver</label><textarea rows="3">Garage is on the right side of the house. Buyer will be in front yard waiting.</textarea></div>
        <button class="Btn Block">Confirm order — pay $48,500 on delivery</button>
    </div>
</div>
