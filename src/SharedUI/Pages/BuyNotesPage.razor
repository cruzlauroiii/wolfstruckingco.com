@page "/Buy/Notes"

<div class="Stage" style="padding:14px">
    <h1 style="font-size:1.4rem;margin-bottom:6px">Special instructions</h1>
    <p style="color:var(--text-muted);font-size:.9rem;margin-bottom:14px">Step 5 of 5 — any extra requests for the driver.</p>
    <div style="display:flex;gap:4px;margin-bottom:14px"><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div></div>

    <div class="Card" style="padding:14px">
        <div style="display:flex;flex-direction:column;gap:8px">
            <label style="display:flex;align-items:center;gap:8px;font-size:.92rem"><input type="checkbox" checked /> Photo proof of delivery required</label>
            <label style="display:flex;align-items:center;gap:8px;font-size:.92rem"><input type="checkbox" checked /> Photo ID check at door</label>
            <label style="display:flex;align-items:center;gap:8px;font-size:.92rem"><input type="checkbox" /> Park in driveway, do not block street</label>
            <label style="display:flex;align-items:center;gap:8px;font-size:.92rem"><input type="checkbox" /> Call 15 minutes before arrival</label>
            <label style="display:flex;align-items:center;gap:8px;font-size:.92rem"><input type="checkbox" checked /> Add cargo insurance ($150)</label>
        </div>
        <div class="Field" style="margin-top:10px"><label>Note for the driver</label><textarea rows="3">Garage is on the right side of the house. Buyer will be in front yard waiting.</textarea></div>
        <button class="Btn Block">Confirm order — pay $48,500 on delivery</button>
    </div>
</div>
