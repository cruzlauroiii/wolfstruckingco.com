@page "/Sell/Vehicle"

<div class="Stage" style="padding:14px">
    <h1 style="font-size:1.4rem;margin-bottom:6px">Vehicle details</h1>
    <p style="color:var(--text-muted);font-size:.9rem;margin-bottom:14px">Step 1 of 5 — tell drivers what they're picking up.</p>
    <div style="display:flex;gap:4px;margin-bottom:14px"><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--border)"></div><div style="flex:1;height:4px;background:var(--border)"></div><div style="flex:1;height:4px;background:var(--border)"></div><div style="flex:1;height:4px;background:var(--border)"></div></div>

    <div class="Card" style="padding:14px">
        <div class="Field"><label>Title</label><input type="text" value="2024 BYD Han EV (China origin)" /></div>
        <div class="Row"><div class="Field"><label>Year</label><input type="text" value="2024" /></div><div class="Field"><label>Color</label><input type="text" value="Crystal White" /></div></div>
        <div class="Field"><label>VIN</label><input type="text" value="LGXC76ED7N4123456" /></div>
        <div class="Field"><label>Condition</label><select><option>Factory sealed — never driven</option><option>New — delivery miles</option><option>Used</option></select></div>
        <button class="Btn Block">Next · pickup</button>
    </div>
</div>
