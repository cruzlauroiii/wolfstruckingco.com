@page "/Sell/Dropoff"

<div class="Stage" style="padding:14px">
    <h1 style="font-size:1.4rem;margin-bottom:6px">Drop-off at the buyer</h1>
    <p style="color:var(--text-muted);font-size:.9rem;margin-bottom:14px">Step 4 of 5 — where the car is delivered.</p>
    <div style="display:flex;gap:4px;margin-bottom:14px"><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--border)"></div></div>

    <div class="Card" style="padding:14px">
        <div class="Field"><label>Drop-off address</label>
            <input type="text" list="to-options" value="1418 Oak Street, Wilmington NC 28401" />
            <datalist id="to-options">
                <option value="1418 Oak Street, Wilmington NC 28401"></option>
                <option value="100 W 33rd St, New York NY 10001"></option>
                <option value="200 Spring Street, San Francisco CA 94110"></option>
                <option value="Trafalgar Square, London WC2N, United Kingdom"></option>
                <option value="Champs-Élysées, 75008 Paris, France"></option>
                <option value="Marina Bay Sands, Singapore"></option>
                <option value="Burj Khalifa, Dubai, UAE"></option>
                <option value="Phoenix AZ relay yard"></option>
                <option value="Memphis TN 24/7 drop yard"></option>
            </datalist>
        </div>
        <div class="Field"><label>Buyer contact</label><input type="text" value="Buyer · Wilmington" /></div>
        <div class="Row"><div class="Field"><label>Phone</label><input type="text" value="+1 910 555 0148" /></div><div class="Field"><label>Reach until</label><input type="text" value="22:00 local" /></div></div>
        <button class="Btn Block">Next · pay & badges</button>
    </div>
</div>
