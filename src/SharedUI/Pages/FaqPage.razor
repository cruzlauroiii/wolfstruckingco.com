@page "/FAQ"

<MarketingHero Title="Frequently asked"
               Highlight="questions"
               Subtitle="Quick answers about pricing, hiring, service area, and how the platform works." />

<div class="Card">
    @foreach (var Q in Questions)
    {
        <details style="margin-bottom:14px;border-bottom:1px solid var(--wt-border);padding-bottom:14px">
            <summary style="font-weight:700;font-size:1.05rem;cursor:pointer;padding:6px 0">@Q.Q</summary>
            <p style="color:var(--wt-text-muted);margin-top:8px;line-height:1.6">@Q.A</p>
        </details>
    }
</div>

