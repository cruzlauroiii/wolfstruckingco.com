@page "/Sell/Pickup"

<div class="Stage" style="padding:14px">
    <h1 style="font-size:1.4rem;margin-bottom:6px">Pickup at the factory</h1>
    <p style="color:var(--text-muted);font-size:.9rem;margin-bottom:14px">Step 2 of 5 — where and how the driver picks up the car.</p>
    <div style="display:flex;gap:4px;margin-bottom:14px"><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--accent)"></div><div style="flex:1;height:4px;background:var(--border)"></div><div style="flex:1;height:4px;background:var(--border)"></div><div style="flex:1;height:4px;background:var(--border)"></div></div>

    <div class="Card" style="padding:14px">
        <div class="Field"><label>Pickup address</label>
            <input type="text" list="from-options" value="BYD Hefei plant, Anhui, China" />
            <datalist id="from-options">
                <option value="BYD Hefei plant, Anhui, China"></option>
                <option value="BYD Shenzhen plant, China"></option>
                <option value="Port of Shenzhen, China"></option>
                <option value="Port of Hong Kong, Kwai Chung"></option>
                <option value="Port of Singapore, Tuas Mega Terminal"></option>
                <option value="Port of Rotterdam, Maasvlakte"></option>
                <option value="Port of Hamburg, Germany"></option>
                <option value="Port of Long Beach, California"></option>
                <option value="Port of Los Angeles — terminal 401"></option>
                <option value="Port of New York / New Jersey, APM Elizabeth"></option>
                <option value="Port of Dubai (Jebel Ali), UAE"></option>
            </datalist>
        </div>
        <div class="Row"><div class="Field"><label>Gate / dock</label><input type="text" value="Gate B · Dock 3" /></div><div class="Field"><label>Pickup hours</label><input type="text" value="08:00 – 18:00" /></div></div>
        <div class="Field"><label>Factory contact</label><input type="text" value="Mr. Liu · BYD export desk" /></div>
        <div class="Row"><div class="Field"><label>Phone</label><input type="text" value="+86 551 555 0142" /></div><div class="Field"><label>WeChat</label><input type="text" value="byd-hefei-export" /></div></div>
        <div class="Field"><label>Cash to pay at pickup</label><input type="text" value="$18,000 USD" /></div>
        <div class="Field"><label>Special instructions</label><textarea rows="2">Bring printed COR and customs broker letter. Photograph the seal numbers before leaving. Do not break the factory wrap.</textarea></div>
        <button class="Btn Block">Next · shipping</button>
    </div>
</div>
