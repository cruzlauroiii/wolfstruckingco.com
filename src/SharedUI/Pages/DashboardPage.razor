@page "/Dashboard"

<div class="Stage" style="padding:14px">
    <div style="font-size:1.4rem;font-weight:800;color:var(--accent);margin-bottom:2px">@Greeting</div>
    <p style="color:var(--text-muted);font-size:.86rem;margin-bottom:14px">Your next job, your earnings, your turn-by-turn.</p>

    @if (NextJob is not null)
    {
        <div class="Card" style="background:linear-gradient(135deg,#fff5e6 0%,rgba(255,107,53,.06) 100%);border:2px solid var(--accent);padding:16px;margin-bottom:14px">
            <div style="font-size:.74rem;text-transform:uppercase;letter-spacing:1.2px;color:var(--accent);font-weight:800;margin-bottom:6px">New job offer</div>
            <div style="font-weight:800;font-size:1.1rem;line-height:1.3;margin-bottom:8px">@(NextJob["from"]?.ToString())  →  @(NextJob["to"]?.ToString())</div>
            <div style="display:flex;gap:14px;color:var(--text-muted);font-size:.86rem;margin-bottom:14px">
                <span>📏 @(NextJob["mileage"]?.ToString()) mi</span>
                <span>⏱️ @(NextJob["driveHours"]?.ToString()) hr</span>
            </div>
            <div style="display:flex;gap:8px">
                <a href="Job/Offer" class="Btn" style="flex:1">Accept job</a>
                <a href="Map" class="Btn Ghost" style="flex:1">Preview route</a>
            </div>
        </div>
    }
    else
    {
        <div class="Card" style="background:#f3f6fa;padding:16px;text-align:center;margin-bottom:14px">
            <div style="font-size:2rem;margin-bottom:6px">😎</div>
            <div style="font-weight:700">No job offers right now</div>
            <div style="color:var(--text-muted);font-size:.84rem;margin-top:4px">We'll text you when one is dispatched.</div>
        </div>
    }

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">
        <div class="Card" style="padding:14px;text-align:center">
            <div style="color:var(--text-muted);font-size:.7rem;text-transform:uppercase;letter-spacing:.7px;font-weight:700;margin-bottom:4px">This week</div>
            <div style="color:#14532d;font-size:1.5rem;font-weight:800">$@WeekEarnings</div>
        </div>
        <div class="Card" style="padding:14px;text-align:center">
            <div style="color:var(--text-muted);font-size:.7rem;text-transform:uppercase;letter-spacing:.7px;font-weight:700;margin-bottom:4px">Hours left</div>
            <div style="color:#1e40af;font-size:1.5rem;font-weight:800">7.5</div>
        </div>
    </div>

    <div style="font-size:.74rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);font-weight:700;margin-bottom:8px">Quick links</div>
    <div style="display:flex;flex-direction:column;gap:8px">
        <a href="Schedule" class="Btn Ghost Block">📅 Schedule</a>
        <a href="Dispatcher" class="Btn Ghost Block">📞 Call agent</a>
        <a href="Documents" class="Btn Ghost Block">📎 My documents</a>
    </div>
</div>
