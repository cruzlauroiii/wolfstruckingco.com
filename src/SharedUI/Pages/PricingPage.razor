@page "/Pricing"

<MarketingHero Title="Simple, transparent"
               Highlight="pricing"
               Subtitle="Pay $1.45 per mile base, no hidden fees. Surcharges only when you ship over 10,000 lbs or need rush delivery." />

<div class="Grid">
    <div class="Card">
        <h2>💵 Base rate</h2>
        <div class="Value">$1.45 / mi</div>
        <p>All freight modes — drayage, LTL, FTL, reefer.</p>
    </div>
    <div class="Card">
        <h2>🛣️ Multi-stop</h2>
        <div class="Value">+$25 / stop</div>
        <p>Each additional pickup or delivery beyond the first.</p>
    </div>
    <div class="Card">
        <h2>⚡ Rush delivery</h2>
        <div class="Value">+30%</div>
        <p>Same-day or guaranteed delivery time windows.</p>
    </div>
    <div class="Card">
        <h2>🏗️ Heavy freight</h2>
        <div class="Value">+$0.15 / lb</div>
        <p>Over 10,000 lbs.</p>
    </div>
</div>
