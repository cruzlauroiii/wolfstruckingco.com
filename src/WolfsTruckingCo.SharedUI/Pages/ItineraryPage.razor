@page "/Itinerary"

<div class="page-header">
    <h1>Itinerary</h1>
    <div class="page-subtitle">Jake Martinez &mdash; Tuesday, April 15, 2026 &mdash; 4 deliveries, 287 miles, 44.2 gal fuel</div>
</div>

<div class="itinerary-timeline">
    @foreach (var Stop in Stops)
    {
        <div class="timeline-item">
            <div class="timeline-time">@Stop.ArrivalTime.ToString("h:mm tt") &ndash; @Stop.DepartureTime.ToString("h:mm tt") (@Stop.DurationMinutes min)</div>
            <div class="timeline-location">@Stop.LocationName</div>
            <div class="timeline-detail">
                <strong>@Stop.Activity</strong><br />
                @Stop.Address<br />
                @Stop.Notes
            </div>
            <div class="timeline-coords">@Stop.Latitude.ToString("F4"), @Stop.Longitude.ToString("F4")</div>
        </div>
    }
</div>

