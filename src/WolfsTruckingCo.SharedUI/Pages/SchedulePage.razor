@page "/Schedule"

<div class="page-header">
    <h1>Daily Schedule</h1>
    <div class="page-subtitle">Jake Martinez &mdash; Tuesday, April 15, 2026 &mdash; Wolfs Trucking Co Depot, Lenoir, NC</div>
</div>

<div class="stats-grid">
    <div class="card">
        <div class="card-value">@TotalDrivingHours</div>
        <div class="card-label">Driving Hours</div>
    </div>
    <div class="card">
        <div class="card-value">@TotalMiles</div>
        <div class="card-label">Total Miles</div>
    </div>
    <div class="card">
        <div class="card-value">@DeliveryCount</div>
        <div class="card-label">Deliveries</div>
    </div>
    <div class="card">
        <div class="card-value">@FuelNeeded</div>
        <div class="card-label">Fuel Gallons</div>
    </div>
</div>

<div class="card">
    <h2 class="card-title">Shift Timeline</h2>
    <table class="schedule-table">
        <thead>
            <tr>
                <th>Time</th>
                <th>Duration</th>
                <th>Activity</th>
                <th>Location</th>
                <th>Miles</th>
                <th>Type</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var Entry in ScheduleEntries)
            {
                <tr class="@(Entry.IsCompleted ? "completed-row" : "")">
                    <td>@Entry.StartTime.ToString("h:mm tt") &ndash; @Entry.EndTime.ToString("h:mm tt")</td>
                    <td>@Entry.DurationMinutes min</td>
                    <td>@Entry.Activity</td>
                    <td>@Entry.Location</td>
                    <td>@(Entry.MilesFromPrevious > 0 ? Entry.MilesFromPrevious.ToString("F1") : "&mdash;")</td>
                    <td><span class="badge @GetTypeBadge(Entry.StopType)">@Entry.StopType</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="card">
    <h2 class="card-title">HOS Compliance</h2>
    <table class="schedule-table">
        <thead>
            <tr>
                <th>Regulation</th>
                <th>Limit</th>
                <th>Used</th>
                <th>Remaining</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Daily Driving</td>
                <td>@ScheduleConstants.MaxDrivingHoursPerDay hrs</td>
                <td>@TotalDrivingHours</td>
                <td>@RemainingDriving</td>
            </tr>
            <tr>
                <td>On-Duty Window</td>
                <td>@ScheduleConstants.MaxOnDutyHoursPerDay hrs</td>
                <td>@OnDutyHours</td>
                <td>@RemainingOnDuty</td>
            </tr>
            <tr>
                <td>Mandatory Break</td>
                <td>@ScheduleConstants.MandatoryBreakMinutes min after @(ScheduleConstants.BreakAfterDrivingMinutes / ScheduleConstants.MinutesPerHour) hrs</td>
                <td>Taken at 12:10 PM</td>
                <td>Compliant</td>
            </tr>
            <tr>
                <td>Weekly Driving</td>
                <td>@ScheduleConstants.MaxDrivingHoursPerWeek hrs</td>
                <td>@WeeklyDriving</td>
                <td>@RemainingWeekly</td>
            </tr>
        </tbody>
    </table>
</div>

