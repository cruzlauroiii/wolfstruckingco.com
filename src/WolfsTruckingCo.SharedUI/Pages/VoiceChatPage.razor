@page "/VoiceChat"

<div class="page-header">
    <h1>Voice Chat</h1>
    <div class="page-subtitle">MCP-powered dispatch communication</div>
</div>

<div class="voicechat-container">
    <div class="voicechat-status">
        <div class="status-dot @(IsConnected ? "" : "offline")"></div>
        <span>@(IsConnected ? "Connected to dispatch" : "Disconnected")</span>
        <span style="margin-left: auto; font-size: 13px; color: var(--wt-text-muted);">
            @VoiceChatConstants.ServerName v@VoiceChatConstants.ServerVersion
        </span>
    </div>

    <div class="card">
        <h2 class="card-title">Connection Details</h2>
        <table class="schedule-table">
            <tbody>
                <tr>
                    <td>Protocol</td>
                    <td>MCP @VoiceChatConstants.McpProtocolVersion</td>
                </tr>
                <tr>
                    <td>WebSocket Port</td>
                    <td>@VoiceChatConstants.WebSocketPort</td>
                </tr>
                <tr>
                    <td>Voice</td>
                    <td>@VoiceChatConstants.DefaultVoice</td>
                </tr>
                <tr>
                    <td>Timeout</td>
                    <td>@VoiceChatConstants.MessageTimeoutSeconds seconds</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="voicechat-messages">
        @foreach (var Message in Messages)
        {
            <div class="message @(Message.IsUser ? "message-user" : "message-system")">
                <div style="font-size: 12px; opacity: 0.7; margin-bottom: 4px;">
                    @(Message.IsUser ? "Driver" : "Dispatch") &mdash; @Message.Timestamp.ToString("h:mm tt")
                </div>
                @Message.Text
            </div>
        }
    </div>

    <div style="margin-top: 16px; display: flex; gap: 8px;">
        <button class="btn btn-primary" @onclick="ToggleConnection">
            @(IsConnected ? "Disconnect" : "Connect")
        </button>
        <button class="btn btn-outline" disabled="@(!IsConnected)">
            Push to Talk
        </button>
    </div>
</div>

@code {
    private bool IsConnected = true;
    private List<ChatMessage> Messages = new();

    protected override void OnInitialized()
    {
        Messages = new List<ChatMessage>
        {
            new() { Text = "Good morning Jake. Your route is loaded for today. 4 deliveries, 287 miles. First pickup at Hickory warehouse.", IsUser = false, Timestamp = new DateTime(2026, 4, ScheduleConstants.PreTripInspectionMinutes, 5, 2, 0) },
            new() { Text = "Copy that dispatch. Pre-trip complete, heading to Hickory now.", IsUser = true, Timestamp = new DateTime(2026, 4, ScheduleConstants.PreTripInspectionMinutes, 5, ScheduleConstants.PreTripInspectionMinutes, 0) },
            new() { Text = "10-4. Blue Ridge Furniture is expecting you at dock 7. BOL is in your tablet.", IsUser = false, Timestamp = new DateTime(2026, 4, ScheduleConstants.PreTripInspectionMinutes, 5, 16, 0) },
            new() { Text = "Loaded up at Hickory. 2,400 lbs furniture. Heading to Charlotte distribution center.", IsUser = true, Timestamp = new DateTime(2026, 4, ScheduleConstants.PreTripInspectionMinutes, 6, 20, 0) },
            new() { Text = "Roger. Traffic on I-77 is clear. ETA 7:45 AM. Charlotte receiving confirmed dock B.", IsUser = false, Timestamp = new DateTime(2026, 4, ScheduleConstants.PreTripInspectionMinutes, 6, 22, 0) },
        };
    }

    private void ToggleConnection()
    {
        IsConnected = !IsConnected;
    }

    private sealed class ChatMessage
    {
        public string Text { get; set; } = string.Empty;
        public bool IsUser { get; set; }
        public DateTime Timestamp { get; set; }
    }
}
