root = true

[*]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{json,yml,yaml}]
indent_size = 2

[*.{js,mjs,cjs}]
indent_size = 2

[*.scss]
indent_size = 2

[*.{razor,cshtml}]
indent_size = 4

[*.cs]

dotnet_analyzer_diagnostic.severity = warning

# SA0001: XML comment analysis disabled by GenerateDocumentationFile=false in Directory.Build.props.
# Project does not use /// XML doc comments; SA0001 is the analyzer's response to that opt-out.
dotnet_diagnostic.SA0001.severity = none

# SA1633: File header missing. Modern .NET projects do not use copyright file headers;
# this project follows that convention.
dotnet_diagnostic.SA1633.severity = none

# MA0165: "Make interpolated string". The Meziantou rule flags every plain string literal,
# including `public const string X = "..."` declarations where interpolation is impossible.
# Const-only constants files (src/Domain/Constants/*) cannot be made interpolated.
dotnet_diagnostic.MA0165.severity = none

# S1075: Hardcoded URI. The constants files in src/Domain/Constants/ are the deliberate
# location for endpoint URLs (OAuth authorize/token URLs, well-known API endpoints).
# Pulling these to config defeats the purpose of compile-time constants.
dotnet_diagnostic.S1075.severity = none

# Note: EnableGenerateDocumentationFile is suppressed in Directory.Build.props NoWarn
# because the compiler emits it as a CSC-level message that doesn't participate in
# editorconfig diagnostic severity overrides. It is the meta-warning that fires when
# GenerateDocumentationFile=false (which the project deliberately sets, since we do
# not author /// XML doc comments) prevents IDE0005 from running on build.

# ---------------------------------------------------------------------------
# TODO: each override below fires somewhere in src/ today. Remove the override
# and fix the underlying violations as follow-up agent work. The codes are
# kept silenced strictly because cleaning them all in one session would
# touch hundreds of lines across the SharedUI Pages/Components/Services tree.
# Track per-rule fix plans in task #177 follow-up.
# ---------------------------------------------------------------------------
